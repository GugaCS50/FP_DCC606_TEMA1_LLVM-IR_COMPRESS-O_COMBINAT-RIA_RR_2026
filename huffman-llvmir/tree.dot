digraph Huffman {
  node [fontname="monospace"];
  n0 [shape=circle, label="12"];
  n1 [shape=box, label="add\n(5)"];
  n0 -> n1 [label="0"];
  n2 [shape=circle, label="7"];
  n3 [shape=box, label="br\n(3)"];
  n2 -> n3 [label="0"];
  n4 [shape=circle, label="4"];
  n5 [shape=box, label="load\n(2)"];
  n4 -> n5 [label="0"];
  n6 [shape=circle, label="2"];
  n7 [shape=box, label="store\n(1)"];
  n6 -> n7 [label="0"];
  n8 [shape=box, label="ret\n(1)"];
  n6 -> n8 [label="1"];
  n4 -> n6 [label="1"];
  n2 -> n4 [label="1"];
  n0 -> n2 [label="1"];
}
